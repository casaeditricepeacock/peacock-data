  },

  "thematic_layers": {
    "aesthetic_framework": ["mono no aware", "ma", "ichigo_ichie", "wabi_sabi"],
    "narrative_mechanics": ["estate_come_misura", "primo_amore_multiplo", "ritorno_al_ryokan"],
    "metaphysical_tags": ["estate_irripetibile", "ryokan_come_continuita", "adolescenza_come_soglia"]
